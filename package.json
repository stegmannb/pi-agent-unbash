{
  "name": "pi-unbash",
  "version": "2.0.0",
  "description": "A highly secure bash confirmation extension for pi, using the unbash AST parser to perfectly intercept subshells and logic gates.",
  "keywords": [
    "pi-package",
    "bash",
    "security",
    "ast",
    "unbash",
    "confirm"
  ],
  "author": "Jason Diamond <jason@diamond.name>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdiamond/pi-unbash.git"
  },
  "homepage": "https://github.com/jdiamond/pi-unbash#readme",
  "bugs": {
    "url": "https://github.com/jdiamond/pi-unbash/issues"
  },
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "test": "npm run check && node --test --experimental-strip-types test/**/*.ts",
    "check": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "unbash": "jdiamond/unbash#combined-fixes"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  }
}
